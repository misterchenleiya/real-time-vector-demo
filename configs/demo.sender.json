{
  "name": "DEMO Sender",
  "processing": {
    "targetFps": 24,
    "processingWidth": 960,
    "processingHeight": 540,
    "maxPaths": 6,
    "minAreaRatio": 0.0025,
    "cannyLowThreshold": 48,
    "cannyHighThreshold": 128,
    "gaussianKernelSize": 5,
    "morphologyIterations": 1,
    "approximationEpsilonRatio": 0.015,
    "resamplePoints": 48,
    "stabilityBlend": 0.7,
    "matchDistanceThreshold": 0.12,
    "loopVideo": true
  },
  "network": {
    "sourceId": "demo-sender-1",
    "listenPort": 50000,
    "fragmentTimeoutMs": 200,
    "targets": [
      {
        "id": "display-a",
        "name": "Receiver A",
        "host": "127.0.0.1",
        "port": 50010,
        "zoneId": "full",
        "scaleX": 1.0,
        "scaleY": 1.0,
        "offsetX": 0.0,
        "offsetY": 0.0
      },
      {
        "id": "display-b",
        "name": "Receiver B",
        "host": "127.0.0.1",
        "port": 50011,
        "zoneId": "left",
        "scaleX": 1.0,
        "scaleY": 1.0,
        "offsetX": 0.0,
        "offsetY": 0.0
      }
    ]
  },
  "zones": [
    {
      "id": "full",
      "x": 0.0,
      "y": 0.0,
      "width": 1.0,
      "height": 1.0
    },
    {
      "id": "left",
      "x": 0.0,
      "y": 0.0,
      "width": 0.5,
      "height": 1.0
    }
  ]
}
